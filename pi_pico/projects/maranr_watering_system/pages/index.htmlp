<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="styles.css">
  <style>
    .logo-container {
        display: flex;
        align-items: center; /* This vertically centers the image and text */
        gap: 20px; /* Adds space between the image and the text column */
    }
    
    .logo-image {
        max-width: 100px; /* Adjust the image width as needed */
        height: auto;
    }
    
    .logo-text-column {
        /* The text will fill the remaining space */
        flex: 1; 
    }
    /* format the H2 next to the image - 'correctly' */
    h2 span {
      display: block; /* Forces each span onto a new line */
    }
    h2 span.major {
      font-size: 50px;
      font-weight: bold;
    }
    h2 span.minor {
      font-size: 30px;
      font-style: italic;
    }
  </style>
  <title>MARANR Watering System</title>
</head>

<body>
    <div class="logo-container">
        <img src="maranr_logo.png" alt="logo" class="logo-image">
        <div class="logo-text-column">
            <h2>
              <span class="major">MARANR</span>
              <span class="minor">&nbsp; &nbsp;Watering System</span>
              <span class="minor">&nbsp; &nbsp;[[date-time]]</span>
            </h2>
        </div>
    </div>

    <p>
      <a href="settings.html">Settings</a>
      &nbsp; &nbsp; 
      <a href="debug.html">Debug</a>
     <br>
       <a href="echo?first=111&second=222&another=more-stuff-here">ECHO test</a> 
       &nbsp;
       <a href="log?linenumber=40&numlines=40">LOG-lines</a> 
    </p>
    <p>
      <a href="viewport_size.html">Viewport size</a>
      &nbsp; &nbsp; 
      <a href="screen_resolution.html">Screen resolution</a>
    </p>
    <p>
      <a href="ex_simple_js_clock_refresh.html">Simple CLOCK: self-updating page JS example</a>
      <br>
      <a href="ex_simple_js_refresh.html">Simple self-updating page JS example</a>
      <br>
      <a href="raw_sensor_data.html">Raw Sensor Data </a>
      <br>
      <a href="ex_get_data_from_server.html">Simple data-fetch JS example</a>
    </p>

    <p>
      <a href="menu1.html">Menu-test</a>
      &nbsp; &nbsp; 
      <a href="squares_red.html">Red Squares</a>
    </p>
    <p>[[memory-status]] </p>
    <p>[[filesystem-status-splitline]]</p>


</body>
</html>
